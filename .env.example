DB_HOST=postgres
DB_PORT=5432
DB_NAME=airflow
DB_USER=airflow
# DB_PASSWORD is the raw PostgreSQL password.
DB_PASSWORD=
# DB_PASSWORD_URI is its URL-encoded form for SQLAlchemy.
# For the simplest local setup, users may choose a password containing only letters, digits, hyphens and underscores, allowing both values to be identical.
DB_PASSWORD_URI=

# FERNET_KEY must remain stable after Airflow starts encrypting values.
FERNET_KEY=

# LLM_API_KEY must never be committed.
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-oss-20b:free

LINKEDIN_JOB_TITLE=Data Engineer
MAX_JOBS_TO_EXTRACT=3
LINKEDIN_LOCATION=Germany

RAW_DIR=/opt/airflow/data/raw
PROCESSED_DIR=/opt/airflow/data/processed

AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_FIRSTNAME=Airflow
AIRFLOW_ADMIN_LASTNAME=Admin
